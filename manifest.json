{
  "name": "Rename & Share",
  "short_name": "RenameAndShare",
  "description": "Rename a file, then share it onward",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#1a1a2e",
  "theme_color": "#4f8ef7",
  "icons": [
    {
      "src": "images/icon-rename-and-share-256.png",
      "sizes": "256x256",
      "type": "image/png"
    },
    {
      "src": "images/icon-rename-and-share-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["*/*"]
        }
      ]
    }
  }
}
